<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".app.MainActivity">

    <RelativeLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        >

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@mipmap/title"
            android:scaleType="fitCenter"
            />

        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/start_Game"
            android:onClick="onStartGameClicked"
            android:layout_centerInParent="true"
            android:translationY="200dp"
            />

        <Button
            android:id="@+id/settingButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setting"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_margin="20dp"
            />

        <Button
            android:id="@+id/characterSettingButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/character_setting"
            android:layout_alignParentBottom="true"
            android:layout_margin="10dp"
            />

    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/characterLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="#FFFFFFFF"
        android:clickable="true"
        android:focusable="true">

        <Button
            android:id="@+id/closeButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="back"
            android:layout_alignParentTop="true"
            android:layout_alignParentStart="true"
            android:layout_margin="20dp"/>

        <ImageView
            android:id="@+id/characterImg"
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:layout_centerInParent="true"
            android:scaleType="fitCenter"
            />

        <ImageButton
            android:id="@+id/selectButton"
            android:layout_width="140dp"
            android:layout_height="70dp"
            android:layout_below="@id/characterImg"
            android:layout_centerHorizontal="true"
            android:src="@drawable/select_btn_selector"
            android:scaleType="centerCrop"
            android:layout_marginTop="50dp"
            android:background="@null"
            android:onClick="onSelectCliked"/>

        <ImageButton
            android:id="@+id/leftButton"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_below="@id/characterImg"
            android:layout_toStartOf="@id/selectButton"
            android:layout_marginEnd="20dp"
            android:src="@drawable/prev_selector"
            android:scaleType="centerCrop"
            android:layout_marginTop="50dp"
            android:background="@null"
            android:onClick="onPrevCliked"/>

        <ImageButton
            android:id="@+id/rightButton"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_below="@id/characterImg"
            android:layout_toEndOf="@id/selectButton"
            android:layout_marginStart="20dp"
            android:src="@drawable/next_selector"
            android:scaleType="centerCrop"
            android:layout_marginTop="50dp"
            android:background="@null"
            android:onClick="onNextCliked"/>

    </RelativeLayout>
</FrameLayout>